<Page
    x:Class="Project_CNPM.Views.AdminPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Padding="20" Spacing="10">

        <!-- Input -->
        <TextBox x:Name="title" PlaceholderText="Tên sách"/>
        <TextBox x:Name="author" PlaceholderText="Tác giả"/>
        <TextBox x:Name="category" PlaceholderText="Thể loại"/>
        <TextBox x:Name="quantity" PlaceholderText="Số lượng"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="Thêm" Click="Add_Click"/>
            <Button Content="Sửa" Click="Update_Click"/>
            <Button Content="Xóa" Click="Delete_Click"/>
            <Button Content="User" Click="LoadUser_Click"/>
            <Button Content="Đăng xuất" Click="Logout_Click"/>
            <Button Content="Xem mượn/trả" Click="BorrowList_Click"/>
            <Button Content="📚 Xem danh sách sách" Click="LoadBooks_Click"/>
        </StackPanel>

        <!-- List -->
        <StackPanel Padding="20" Spacing="10">

            <Button Content="📚 Xem danh sách sách" Click="LoadBooks_Click"/>
            <Button Content="📖 Xem mượn/trả" Click="BorrowList_Click"/>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="20">
                <TextBlock Text="ID" Width="30" FontWeight="Bold"/>
                <TextBlock Text="Title" Width="150" FontWeight="Bold"/>
                <TextBlock Text="Author" Width="120" FontWeight="Bold"/>
                <TextBlock Text="Category" Width="100" FontWeight="Bold"/>
                <TextBlock Text="Qty" Width="50" FontWeight="Bold"/>
            </StackPanel>

            <!-- LISTVIEW -->
            <ListView x:Name="list">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <TextBlock Text="{Binding Id}" Width="30"/>
                            <TextBlock Text="{Binding Title}" Width="150"/>
                            <TextBlock Text="{Binding Author}" Width="120"/>
                            <TextBlock Text="{Binding Category}" Width="100"/>
                            <TextBlock Text="{Binding Quantity}" Width="50"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </StackPanel>
</Page>