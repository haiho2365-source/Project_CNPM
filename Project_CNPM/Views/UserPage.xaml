<Page
    x:Class="Project_CNPM.Views.UserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Padding="20" Spacing="10">

        <!-- Search -->
        <TextBox x:Name="txtSearch" PlaceholderText="Tìm theo tên hoặc tác giả"/>
        <Button Content="Tìm kiếm" Click="Search_Click"/>

        <!-- Filter -->
        <ComboBox x:Name="cbCategory">
            <ComboBoxItem Content="All"/>
            <ComboBoxItem Content="IT"/>
            <ComboBoxItem Content="Math"/>
        </ComboBox>
        <Button Content="Lọc" Click="Filter_Click"/>

        <!-- Book list -->
        <ListView x:Name="list">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="{Binding Title}" Width="150"/>
                        <TextBlock Text="{Binding Author}" Width="120"/>
                        <TextBlock Text="{Binding Category}" Width="100"/>
                        <TextBlock Text="{Binding Quantity}" Width="50"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <!-- Actions -->
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="Mượn sách" Click="Borrow_Click"/>
            <Button Content="Trả sách" Click="Return_Click"/>
            <Button Content="Sách đã mượn" Click="MyBooks_Click"/>
            <Button Content="Đăng xuất" Click="Logout_Click"/>
        </StackPanel>

    </StackPanel>
</Page>